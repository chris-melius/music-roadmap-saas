@page "/register"
@using MusicRoadmap.Shared.DTOs
@using MusicRoadmap.Client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

@attribute [AllowAnonymous]

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">Teacher Registration</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted text-center mb-4">Start building professional roadmaps for your students.</p>

                    <EditForm Model="registerModel" OnValidSubmit="HandleRegistration">
                        <DataAnnotationsValidator />
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">First Name</label>
                                <InputText @bind-Value="registerModel.FirstName" class="form-control" placeholder="Johann" />
                                <ValidationMessage For="@(() => registerModel.FirstName)" class="text-danger small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Last Name</label>
                                <InputText @bind-Value="registerModel.LastName" class="form-control" placeholder="Bach" />
                                <ValidationMessage For="@(() => registerModel.LastName)" class="text-danger small" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <InputText @bind-Value="registerModel.Email" class="form-control" placeholder="j.bach@leipzig.de" />
                            <ValidationMessage For="@(() => registerModel.Email)" class="text-danger small" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Password</label>
                            <InputText @bind-Value="registerModel.Password" type="password" class="form-control" placeholder="********" />
                            <ValidationMessage For="@(() => registerModel.Password)" class="text-danger small" />
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Creating Account...</span>
                            }
                            else
                            {
                                <span>Register as Instructor</span>
                            }
                        </button>
                    </EditForm>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-4 small">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
                        </div>
                    }
                </div>
                <div class="card-footer bg-light text-center py-3">
                    <span class="text-muted">Already have an account?</span>
                    <a href="/login" class="ms-2 text-decoration-none">Login here</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterDto registerModel = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleRegistration()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var response = await AuthService.Register(registerModel);

            if (response.IsSuccessStatusCode)
            {
                // Navigate to login on success
                Navigation.NavigateTo("/login");
            }
            else
            {
                // Pull out Identity errors if available
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Registration failed: {errorContent}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "A connection error occurred. Is the API running? " + "Exception: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}