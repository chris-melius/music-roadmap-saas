@page "/integrations"
@using MusicRoadmap.Shared.DTOs
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-plug-fill text-primary me-2"></i>External Integrations</h2>
            <p class="text-muted mb-0">Manage API keys to connect your personal studio website forms (WordPress, Squarespace, etc.)</p>
        </div>
        <button class="btn btn-primary shadow-sm" @onclick="OpenCreateModal" disabled="@isActionLoading">
            <i class="bi bi-key-fill me-2"></i>Generate New Key
        </button>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (!apiKeys.Any())
    {
        <div class="card text-center p-5 border-dashed bg-light">
            <div class="card-body">
                <i class="bi bi-shield-lock-fill text-muted display-4 mb-3"></i>
                <h5>No Active Integrations</h5>
                <p class="text-muted">Generate an API key to start securely funneling new parents from your personal website forms directly into your dashboard.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Website URL</th>
                            <th>Created On</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var key in apiKeys)
                        {
                            <tr>
                                <td class="fw-semibold">@key.WebsiteURL</td>
                                <td class="text-muted">@key.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge @(key.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") border">
                                        @(key.IsActive ? "Active" : "Revoked")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RevokeKey(key.Id)" disabled="@isActionLoading">
                                        <i class="bi bi-trash3-fill"></i> Revoke
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* MODAL: GENERATE / DISPLAY NEW KEY *@
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-shield-plus me-2"></i>Configure Integration Key</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (string.IsNullOrEmpty(newRawKey))
                    {
                        <EditForm Model="createModel" OnValidSubmit="HandleGenerateKey">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Your Website URL</label>
                                <InputText @bind-Value="createModel.WebsiteURL" class="form-control" placeholder="e.g., https://my-piano-studio.com" required />
                                <div class="form-text">Used to restrict cross-origin access and track lead pipelines.</div>
                            </div>
                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary">Create Cryptographic Token</button>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <div class="alert alert-warning border border-warning d-flex align-items-start" role="alert">
                            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2 fs-5"></i>
                            <div>
                                <strong>Copy this key now!</strong> For security compliance, it is heavily encrypted on the server and will <strong>never</strong> be displayed to you again.
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">X-API-KEY Value</label>
                            <div class="input-group">
                                <input type="text" class="form-control font-monospace bg-light" value="@newRawKey" readonly />
                            </div>
                        </div>
                        <div class="d-grid mt-4">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">I Have Copied the Key</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ApiKeyResponseDto> apiKeys = new();
    private CreateApiKeyDto createModel = new();
    private string newRawKey = string.Empty;
    private bool isLoading = true;
    private bool isActionLoading = false;
    private bool showModal = false;

    private HttpClient secureClient = default!;

    protected override async Task OnInitializedAsync()
    {
        secureClient = HttpClientFactory.CreateClient("SecureApi");
        await LoadKeys();
    }

    private async Task LoadKeys()
    {

        isLoading = true;
        
        try
        {
            apiKeys = await secureClient.GetFromJsonAsync<List<ApiKeyResponseDto>>("api/instructor/apikeys") ?? new();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Failed to download keys payload: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateModal()
    {
        createModel = new();
        newRawKey = string.Empty;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        newRawKey = string.Empty;
    }

    private async Task HandleGenerateKey()
    {
        isActionLoading = true;
        try
        {
            var response = await secureClient.PostAsJsonAsync("api/instructor/apikeys", createModel);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<GeneratedKeyResultDto>();
                if (result != null)
                {
                    newRawKey = result.RawKey;
                    await LoadKeys(); // Refresh backend data grids
                }
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Key allocation failed: {ex.Message}");
        }
        finally
        {
            isActionLoading = false;
        }
    }

    private async Task RevokeKey(Guid id)
    {
        isActionLoading = true;
        try
        {
            var response = await secureClient.DeleteAsync($"api/instructor/apikeys/{id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadKeys();
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Revocation execution dropped: {ex.Message}");
        }
        finally
        {
            isActionLoading = false;
        }
    }
}